proxy-groups:
  - name: 🚀 Proxy
    type: select
    proxies:
      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - '🚩 CF | 🔒 VLESS | @NamiraConfigs [60]'
      - '🚩 CF | 🔒 VLESS | @NamiraConfigs [61]'
      - '🇫🇮 FI | 🔓 VLESS | @NamiraConfigs [62]'
