      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - '🚩 CF | 🔒 VLESS | @NamiraConfigs [56]'
