proxy-groups:
  - name: 🚀 Proxy
    type: select
    proxies:
      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - '🇳🇱 NL | 🔓 VLESS | @NamiraConfigs [63]'
      - '🚩 CF | 🔒 VLESS | @NamiraConfigs [64]'
      - '🇺🇸 US | 🔓 VMESS | @NamiraConfigs [65]'

  - name: 🌍 Global Media
    type: select
    proxies:
      - 🚀 Proxy
      - ♻️ Auto
      - 🎯 Direct

  - name: 🎯 Direct
    type: select
    proxies:
      - DIRECT

  - name: 🛑 Ad Block
    type: select
    proxies:
      - REJECT
      - DIRECT

  - name: 🐟 Fallback
    type: select
    proxies:
      - 🚀 Proxy
      - 🎯 Direct

rules:
