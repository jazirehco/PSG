      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - '🚩 CF | 🔒 VLESS | @NamiraConfigs [61]'
      - '🇮🇷 IR | 🔓 VLESS | @NamiraConfigs [62]'
      - '🇩🇪 DE | 🔒 VLESS | @NamiraConfigs [63]'

  - name: 🌍 Global Media
    type: select
    proxies:
      - 🚀 Proxy
      - ♻️ Auto
      - 🎯 Direct

  - name: 🎯 Direct
    type: select
    proxies:
      - DIRECT

  - name: 🛑 Ad Block
    type: select
    proxies:
      - REJECT
      - DIRECT

  - name: 🐟 Fallback
    type: select
    proxies:
      - 🚀 Proxy
      - 🎯 Direct

